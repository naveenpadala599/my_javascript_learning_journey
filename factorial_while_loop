while(true){
    let number = prompt("Enter the number: ");
    number=parseInt(number);
        if (number<0){
            console.log("Enter a positive number.");
            continue;
        }
        else if(number===0){
            console.log(1);
            continue;
        }
        else if(isNaN(number)){
            console.log("Enter a number.");
            continue;
        }
        else{
            let factorial=1;
            while (number > 0){
                factorial=factorial*(number);
                number=number-1;
            }
            console.log(factorial);
        }
        continue;
    }
