const suits = ["Spades","Diomands","Clubs","Hearts"];
const values = ["Ace","2","3","4","5","6","7","8","9","10","Jack","Queen","King"];
let deck = [];
for(let i = 0; i<suits.length; i++){
    for(let x=0; x<values.length; x++){
        let card={value: values[x], suits: suits[i]};
        deck.push(card)
    }
}
console.log(deck)
